{
  "$schema": "https://railway.app/railway.schema.json",
  "build": {
    "builder": "DOCKERFILE",
    "dockerfilePath": "Dockerfile"
  },
  "deploy": {
    "startCommand": "cd backend && npx prisma migrate deploy && node dist/index.js",
    "healthcheckPath": "/api/health",
    "healthcheckTimeout": 120
  }
}
