{
  "$schema": "https://railway.app/railway.schema.json",
  "build": {
    "builder": "NIXPACKS",
    "buildCommand": "cd frontend && npm install && VITE_API_BASE_URL=/api npm run build"
  },
  "deploy": {
    "startCommand": "python server.py",
    "healthcheckPath": "/api/health",
    "healthcheckTimeout": 60
  }
}
